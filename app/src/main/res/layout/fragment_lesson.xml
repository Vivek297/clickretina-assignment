<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ============ VIDEO PLAYER AREA ============ -->
        <FrameLayout
            android:id="@+id/videoArea"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@drawable/bg_video_hero">

            <!-- Underlying Video View -->
            <VideoView
                android:id="@+id/video_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Faded background title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:alpha="0.15"
                android:text="Kotlin\nFundamentals"
                android:textColor="@android:color/white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Category tag -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginTop="-8dp"
                android:layout_marginBottom="72dp"
                android:background="@drawable/bg_tag_chip"
                android:fontFamily="monospace"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="// kotlin"
                android:textColor="@color/on_surface"
                android:textSize="12sp" />

            <!-- Back button -->
            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_video_control">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="Back"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <!-- Fullscreen button -->
            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_video_control">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="Fullscreen"
                    android:src="@android:drawable/ic_menu_crop"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <!-- Center Play button -->
            <FrameLayout
                android:id="@+id/btnPlayCenter"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_play_circle"
                android:elevation="6dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="4dp"
                    android:contentDescription="Play"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/on_surface" />
            </FrameLayout>

            <!-- Progress row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="02:14"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Custom progress bar: track + fill + thumb -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_track">

                    <View
                        android:id="@+id/progressFill"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_fill" />

                    <View
                        android:id="@+id/progressThumb"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="122dp"
                        android:background="@drawable/bg_progress_thumb" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="06:00"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- ============ LESSON INFO ============ -->
        <TextView
            android:id="@+id/tvCourseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:letterSpacing="0.08"
            android:paddingHorizontal="16dp"
            android:text="LESSON 1 · KOTLIN FUNDAMENTALS"
            android:textColor="@color/brand"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLessonTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="16dp"
            android:text="Welcome &amp; Setup"
            android:textColor="@color/on_surface"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLessonDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:paddingHorizontal="16dp"
            android:text="Set up Android Studio and run your first Kotlin file."
            android:textColor="@color/on_surface_secondary"
            android:textSize="15sp" />

        <!-- ============ TABS ============ -->
        <LinearLayout
            android:id="@+id/tabsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:id="@+id/tabLessons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="8dp"
                    android:text="Lessons"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/bg_tab_underline" />
            </LinearLayout>

            <TextView
                android:id="@+id/tabNotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:paddingBottom="8dp"
                android:text="Notes"
                android:textColor="@color/on_surface_secondary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabResources"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:paddingBottom="8dp"
                android:text="Resources"
                android:textColor="@color/on_surface_secondary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider under tabs -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="-1dp"
            android:background="@color/border" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLessons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_lesson_player" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>